# ==============================================================================
# AutoReq - Ortam Değişkenleri Şablonu
# ==============================================================================
#
# Bu dosya, projenin çalışması için gereken ortam değişkenlerinin şablonudur.
# Gerçek değerlerinizi içeren bir `.env` dosyası oluşturmak için:
#
#   1. Bu dosyayı kopyalayın:  cp .env.example .env
#   2. Aşağıdaki değerleri kendi API anahtarlarınızla doldurun
#   3. .env dosyası Git'e commit EDİLMEZ (güvenlik için .gitignore'da)
#
# ==============================================================================

# ------------------------------------------------------------------------------
# OPENROUTER API YAPILANDIRMASI (ÖNERİLEN)
# ------------------------------------------------------------------------------
# OpenRouter API anahtarı (ZORUNLU)
#
# API anahtarı almak için:
#   1. https://openrouter.ai/keys adresine gidin
#   2. Hesabınızla giriş yapın
#   3. "Create Key" butonuna tıklayın
#   4. Oluşturulan anahtarı aşağıya yapıştırın
#
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ------------------------------------------------------------------------------
# GEMINI API YAPILANDIRMASI (ALTERNATİF)
# ------------------------------------------------------------------------------
# Google Gemini API anahtarı
GEMINI_API_KEY=your_gemini_api_key_here

# Kullanılacak Gemini model adı (OPSİYONEL)
# Varsayılan: gemini-2.5-flash
#
# Mevcut modeller (Nisan 2026):
#   - gemini-2.5-flash    (hızlı, maliyet-etkin - önerilen)
#   - gemini-2.5-pro      (daha güçlü, daha yavaş)
#
# GEMINI_MODEL_NAME=gemini-2.5-flash

# ------------------------------------------------------------------------------
# GELECEK ENTEGRASYONLAR (Henüz aktif değil)
# ------------------------------------------------------------------------------
# Aşağıdaki değişkenler ileride eklenecek özellikler içindir.
# Şu an için yorum satırı olarak bırakılmıştır.

# OpenAI API (alternatif LLM provider)
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API (alternatif LLM provider)  
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
